# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection used at runtime (pooled). When using the Vercel <->
# Supabase marketplace integration, this is auto-injected and you don't need
# to set it manually.
POSTGRES_PRISMA_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"

# Used by `prisma migrate` - must be the *unpooled* (direct) connection
# string. Also auto-injected by the Vercel <-> Supabase integration.
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname"

# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Public URL of the deployed app, used to build the Steam OpenID return_to
# URL (e.g. https://your-app.vercel.app). Must match the deployed domain.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Random secret used to sign the session cookie. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Google Gemini API key for AI-generated achievement roadmaps (free tier):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# === AIOX Variables (added 2026-06-29) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9
