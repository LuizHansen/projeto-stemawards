# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection string used at runtime (can be a pooled connection on
# providers like Neon/Supabase).
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Used by `prisma migrate` - on a pooled provider this must be the *unpooled*
# connection string. Locally it's the same as DATABASE_URL.
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Public URL of the deployed app, used to build the Steam OpenID return_to
# URL (e.g. https://your-app.vercel.app). Must match the deployed domain.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Random secret used to sign the session cookie. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Google Gemini API key for AI-generated achievement roadmaps (free tier):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
