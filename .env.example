# Copy this file to .env and fill in real values. Never commit .env.

# Postgres connection used at runtime (pooled). When using the Vercel <->
# Supabase marketplace integration, this is auto-injected and you don't need
# to set it manually.
POSTGRES_PRISMA_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"

# Used by `prisma migrate` - must be the *unpooled* (direct) connection
# string. Also auto-injected by the Vercel <-> Supabase integration.
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname"

# Steam Web API key: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=""

# Public URL of the deployed app, used to build the Steam OpenID return_to
# URL (e.g. https://your-app.vercel.app). Must match the deployed domain.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Random secret used to sign the session cookie. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# Google Gemini API key for AI-generated achievement roadmaps (free tier):
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
